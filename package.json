{
  "name": "docscraper-ai",
  "version": "1.0.0",
  "description": "Fast documentation scraper and HTML-to-Markdown converter built for AI agents. Discover, crawl, and extract docs into clean structured Markdown.",
  "keywords": [
    "docscraper",
    "web-scraper",
    "crawler",
    "html-to-markdown",
    "documentation",
    "ai",
    "agent",
    "turndown",
    "cheerio"
  ],
  "license": "MIT",
  "author": "Alex28042",
  "repository": {
    "type": "git",
    "url": "https://github.com/Alex28042/docscraper-ai"
  },
  "homepage": "https://github.com/Alex28042/docscraper-ai#readme",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "docscraper-ai": "dist/cli/cli.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepublishOnly": "npm run clean && npm run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "tests/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "1.13.6",
    "cheerio": "1.0.0",
    "turndown": "7.2.0"
  },
  "devDependencies": {
    "@types/node": "20.0.0",
    "@types/turndown": "5.0.5",
    "@typescript-eslint/eslint-plugin": "8.57.0",
    "@typescript-eslint/parser": "8.57.0",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "tsx": "4.0.0",
    "typescript": "5.5.0",
    "vitest": "4.1.0"
  }
}
